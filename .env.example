# cc-on-wecom 环境变量配置

# 企业微信机器人（不配置则仅 Web 模式可用）
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# 服务端口
PORT=8890

# Claude CLI 路径（留空自动检测: macOS /usr/local/bin/claude, Windows claude.cmd）
CLAUDE_PATH=

# 日志
LOG_FILE=
WECOM_LOG_LEVEL=info

# Context 自动压缩
CONTEXT_COMPACT_THRESHOLD=0.85
CONTEXT_CHECK_EVERY_TURNS=6
CONTEXT_CHECK_STALE_MS=600000
CONTEXT_COMPACT_COOLDOWN_MS=300000
